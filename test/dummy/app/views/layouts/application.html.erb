<!DOCTYPE html>
<html>
<head>
  <title>Revelio Demo</title>
  <script type="module" src="https://unpkg.com/@hotwired/turbo@8/dist/turbo.es2017-esm.js"></script>
  <script type="module">
    import { Application, Controller } from "https://unpkg.com/@hotwired/stimulus/dist/stimulus.js"
    const app = Application.start()
    window.Stimulus = app

    // hello controller
    app.register("hello", class extends Controller {
      static targets = ["name", "output"]
      greet() {
        this.outputTarget.textContent = "Hello, " + this.nameTarget.value + "!"
      }
    })

    // counter controller
    app.register("counter", class extends Controller {
      static targets = ["count"]
      increment() {
        this.countTarget.textContent = (parseInt(this.countTarget.textContent) || 0) + 1
      }
      decrement() {
        this.countTarget.textContent = (parseInt(this.countTarget.textContent) || 0) - 1
      }
    })

    // toggle controller
    app.register("toggle", class extends Controller {
      static targets = ["content"]
      toggle() {
        this.contentTarget.hidden = !this.contentTarget.hidden
      }
    })
  </script>
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; padding: 0; display: flex; min-height: 100vh; }
    nav {
      width: 200px;
      flex-shrink: 0;
      background: #f9fafb;
      border-right: 1px solid #e5e7eb;
      padding: 20px 0;
      font-size: 13px;
      display: flex;
      flex-direction: column;
      gap: 2px;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      overflow-y: auto;
    }
    nav .nav-heading {
      font-size: 11px;
      font-weight: 600;
      color: #9ca3af;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 12px 16px 4px;
    }
    nav .nav-heading:first-child { padding-top: 6px; }
    nav a {
      display: block;
      padding: 6px 16px;
      color: #374151;
      text-decoration: none;
      transition: background 0.15s;
    }
    nav a:hover { background: #e5e7eb; }
    main { margin-left: 200px; padding: 20px 32px 40px; flex: 1; }
    section { margin-bottom: 24px; }
    h2 { font-size: 16px; color: #555; }
    .card { border: 1px solid #ddd; border-radius: 8px; padding: 12px 16px; margin: 8px 0; }
    input[type=text] { padding: 6px 10px; border: 1px solid #ccc; border-radius: 4px; }
    button { padding: 6px 14px; border-radius: 4px; border: 1px solid #ccc; cursor: pointer; }
    button:hover { background: #f3f4f6; }
    .error-example { background: #fef2f2; border: 1px dashed #fca5a5; padding: 12px; border-radius: 8px; margin: 8px 0; }
  </style>
</head>
<body>
<nav>
  <div class="nav-heading">Engines</div>
  <a href="/haml">HAML</a>
  <a href="/slim">Slim</a>
  <a href="/erb">ERB</a>
  <div class="nav-heading">Partials</div>
  <a href="/haml/partial">HAML</a>
  <a href="/slim/partial">Slim</a>
  <a href="/erb/partial">ERB</a>
  <div class="nav-heading">Mixed</div>
  <a href="/haml/mixed">HAML</a>
  <a href="/slim/mixed">Slim</a>
  <a href="/erb/mixed">ERB</a>
  <div class="nav-heading">Components</div>
  <a href="/haml/component">HAML</a>
  <div class="nav-heading">Features</div>
  <a href="/haml/stimulus">Stimulus</a>
  <a href="/haml/posts">Posts (queries)</a>
  <a href="/haml/turbo">Turbo</a>
  <a href="/haml/turbo_linter">Turbo Linter</a>
</nav>
<main>
<%= yield %>
</main>
</body>
</html>
